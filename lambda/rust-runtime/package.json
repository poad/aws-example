{
  "name": "rust-runtime",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "rust-runtime": "bin/rust-runtime.js"
  },
  "scripts": {
    "build": "tsc && cd lambda && cargo build",
    "clean": "tsc --build --clean && cd lambda && cargo clean",
