    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.1",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import-x": "^4.16.2",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.60.1"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.5.1",
